# Optional on Vercel: if omitted, app falls back to sqlite:////tmp/property_registry.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/property_registry
ADMIN_TOKEN=change-me-admin-token
# Local dev: storage
# Vercel: /tmp/storage
STORAGE_PATH=storage
AUTHORIZED_NODES=validator-a,validator-b,validator-c
POA_QUORUM=2
